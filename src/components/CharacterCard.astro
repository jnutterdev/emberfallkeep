---
interface Props {
  name: string;
  player: string;
  characterClass?: string;
  level?: number;
  race?: string;
  active?: boolean;
  portrait?: string;
  href: string;
}
const { name, player, characterClass, level, race, active = true, portrait, href } = Astro.props;
---

<a class="char-card" href={href}>
  <div class="char-card__portrait">
    {portrait
      ? <img src={portrait} alt={name} class="char-card__img" />
      : <i class="fa-solid fa-user char-card__placeholder"></i>
    }
    {!active && <span class="char-card__deceased"><i class="fa-solid fa-skull"></i></span>}
  </div>
  <div class="char-card__body">
    <div class="char-card__name">{name}</div>
    <div class="char-card__sub">
      {race && <span>{race}</span>}
      {characterClass && <span>{characterClass}{level ? ` ${level}` : ''}</span>}
    </div>
    <div class="char-card__player">
      <i class="fa-solid fa-user-group"></i> {player}
    </div>
  </div>
</a>

<style>
  .char-card {
    display: flex; flex-direction: column;
    background: var(--void-surface);
    border: 1px solid var(--border-default);
    text-decoration: none;
    overflow: hidden;
    transition: background 0.15s, border-color 0.15s;
  }
  .char-card:hover { background: var(--void-raised); border-color: var(--border-mist); }
  .char-card:hover .char-card__name { color: var(--mist-bright); }
  .char-card__portrait {
    aspect-ratio: 3/4; overflow: hidden;
    background: var(--void-raised);
    display: flex; align-items: center; justify-content: center;
    position: relative;
  }
  .char-card__img {
    width: 100%; height: 100%; object-fit: cover;
    filter: grayscale(0.4) sepia(0.2);
    mix-blend-mode: luminosity;
  }
  .char-card__placeholder { font-size: 3rem; color: rgba(104,152,168,0.25); }
  .char-card__deceased {
    position: absolute; top: 0.5rem; right: 0.5rem;
    background: rgba(200,136,120,0.2); border: 1px solid rgba(200,136,120,0.4);
    padding: 0.2rem 0.4rem; font-size: 10px; color: var(--mauve-bright);
  }
  .char-card__body { padding: 0.9rem 1rem; }
  .char-card__name {
    font-family: "Cinzel", serif; font-size: 14px; font-weight: 600;
    color: var(--mist-mid); letter-spacing: 0.04em;
    margin-bottom: 0.2rem; transition: color 0.2s;
  }
  .char-card__sub {
    font-family: "Cinzel", serif; font-size: 9px;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-dim); margin-bottom: 0.4rem;
    display: flex; gap: 0.5rem;
  }
  .char-card__sub span + span::before { content: "·"; margin-right: 0.5rem; }
  .char-card__player {
    font-family: "Cinzel", serif; font-size: 9px;
    letter-spacing: 0.08em; color: var(--text-dim);
  }
  .char-card__player i { color: var(--teal-mid); margin-right: 0.3rem; font-size: 8px; }
</style>
