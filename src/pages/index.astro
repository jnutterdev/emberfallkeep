---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

// ── Helpers ───────────────────────────────────────────────────────────────────
function toRoman(num: number): string {
  if (!num || num <= 0) return '–';
  const vals = [1000,900,500,400,100,90,50,40,10,9,5,4,1];
  const syms = ['M','CM','D','CD','C','XC','L','XL','X','IX','V','IV','I'];
  let result = '';
  for (let i = 0; i < vals.length; i++) {
    while (num >= vals[i]) { result += syms[i]; num -= vals[i]; }
  }
  return result;
}

function fmtDate(d: Date | undefined): string {
  if (!d) return '–';
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

function stripSessionPrefix(title: string): string {
  const idx = title.indexOf(' — ');
  return idx >= 0 ? title.slice(idx + 3) : title;
}

function classIcon(cls: string | undefined): string {
  const map: Record<string, string> = {
    Fighter:       'fa-shield-halved',
    Paladin:       'fa-shield-halved',
    Barbarian:     'fa-fire',
    Wizard:        'fa-wand-sparkles',
    Sorcerer:      'fa-star',
    Warlock:       'fa-eye',
    Bard:          'fa-music',
    Cleric:        'fa-cross',
    Druid:         'fa-leaf',
    Ranger:        'fa-bow-arrow',
    Rogue:         'fa-skull',
    Monk:          'fa-hand-fist',
    'Blood Hunter':'fa-droplet',
    Artificer:     'fa-gears',
  };
  return map[cls ?? ''] ?? 'fa-person';
}

// ── Data ──────────────────────────────────────────────────────────────────────
const campaigns      = await getCollection('campaigns');
const activeCampaign = campaigns.find(c => c.data.status === 'Active') ?? campaigns[0];

const allChars = await getCollection('characters');
const characters: CollectionEntry<'characters'>[] = activeCampaign
  ? allChars.filter(c => c.data.campaign === activeCampaign.slug && c.data.active)
  : [];

const allSessRaw = await getCollection('sessions');
const allSessions: CollectionEntry<'sessions'>[] = activeCampaign
  ? allSessRaw
      .filter(s => s.data.campaign === activeCampaign.slug)
      .sort((a, b) => b.data.sessionNumber - a.data.sessionNumber)
  : [];
const recentSessions = allSessions.slice(0, 5);

const allNpcs = await getCollection('npcs');
const npcs: CollectionEntry<'npcs'>[] = activeCampaign
  ? allNpcs.filter(n => n.data.campaign === activeCampaign.slug)
  : [];
const factions = await getCollection('factions');
const items    = await getCollection('items');

const allMapsRaw = await getCollection('maps');
const allMaps: CollectionEntry<'maps'>[] = activeCampaign
  ? allMapsRaw.filter(m => m.data.campaign === activeCampaign.slug)
  : allMapsRaw;
const totalPins  = allMaps.reduce((sum: number, m) => sum + (m.data.pins?.length ?? 0), 0);
---

<Base title="Emberfall Keep" description="A campaign management site for Dungeons & Dragons.">

  <!-- ── HERO ────────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-art">
      <!-- Monogram -->
      <svg
        class="monogram-hero"
        viewBox="0 0 280 200"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <!-- Outer ring -->
        <circle cx="140" cy="100" r="96" stroke="currentColor" stroke-width="0.8" opacity="0.4" fill="none" />
        <!-- Inner ring -->
        <circle cx="140" cy="100" r="90" stroke="currentColor" stroke-width="0.8" opacity="0.4" fill="none" />
        <!-- EK letterform -->
        <text
          x="140"
          y="150"
          text-anchor="middle"
          font-family="Almendra SC, serif"
          font-size="130"
          font-weight="400"
          fill="currentColor"
          opacity="0.9"
        >EK</text>
      </svg>
    </div>

    <div class="hero-content wrap">
      <div>
        <div class="pill-active">Active Campaign</div>
        <h1 class="hero-title">{activeCampaign?.data.title ?? 'Emberfall Keep'}</h1>
      </div>
      <div class="hero-right">
        <p class="hero-tagline">
          {activeCampaign?.data.tagline ?? 'Where campaigns are forged and legends remembered.'}
        </p>
        <div class="hero-actions">
          <a href="#chronicles" class="hero-link">Latest Session</a>
          <a href="#campaign"   class="hero-link">Campaign Detail</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── THE CAMPAIGN ────────────────────────────────────────────────────── -->
  {activeCampaign && (
    <section class="campaign" id="campaign">
      <div class="wrap">
        <h2 class="section-label">The Campaign</h2>
        <div class="campaign-inner">

          <div class="campaign-image">
            {activeCampaign.data.coverImage
              ? <Image src={activeCampaign.data.coverImage} alt={activeCampaign.data.title} width={560} height={740} class="campaign-cover-img" />
              : <i class="fa-solid fa-map"></i>
            }
          </div>

          <div class="campaign-text">
            <p class="campaign-meta">
              <i class="fa-solid fa-compass"></i>
              &nbsp;
              {activeCampaign.data.setting ?? activeCampaign.data.system}
              &nbsp;&middot;&nbsp;
              Session {toRoman(activeCampaign.data.sessionCount)}
              &nbsp;&middot;&nbsp;
              {activeCampaign.data.system}
            </p>

            <h3 class="campaign-title">{activeCampaign.data.title}</h3>

            <p class="campaign-subtitle">
              {activeCampaign.data.tagline ?? 'A campaign of intrigue, ruin, and reckoning'}
            </p>

            {activeCampaign.data.description && (
              <p class="campaign-desc">{activeCampaign.data.description}</p>
            )}

            <p class="campaign-callout">
              Where campaigns are forged<br />and legends remembered.
            </p>

            <div class="campaign-stats">
              <div class="campaign-stat">
                <span class="lbl">Sessions</span>
                <span class="val">{toRoman(activeCampaign.data.sessionCount)}</span>
              </div>
              <div class="campaign-stat">
                <span class="lbl">Last Played</span>
                <span class="val">{fmtDate(activeCampaign.data.lastSession)}</span>
              </div>
              <div class="campaign-stat">
                <span class="lbl">Party Size</span>
                <span class="val">{(activeCampaign.data.partySize ?? characters.length) || '–'}</span>
              </div>
              <div class="campaign-stat">
                <span class="lbl">System</span>
                <span class="val">{activeCampaign.data.system}</span>
              </div>
            </div>

            <a href={`/sessions`} class="btn btn-primary">
              <i class="fa-solid fa-scroll"></i> Latest Session
            </a>
            <a href={`/campaigns/${activeCampaign.slug}`} class="btn btn-ghost">
              <i class="fa-solid fa-dungeon"></i> Full Campaign
            </a>
          </div>

        </div>
      </div>
    </section>
  )}

  <!-- ── THE FELLOWSHIP ──────────────────────────────────────────────────── -->
  <section class="fellowship" id="fellowship">
    <div class="wrap">
      <div class="fellowship-intro">
        <h2 class="section-label">The Fellowship</h2>
        <p class="fellowship-tagline">
          {characters.length > 0
            ? `${characters.length} adventurers. One table. More arguments about loot than any dragon has ever caused.`
            : 'Gather your fellowship and let the adventure begin.'}
        </p>
      </div>

      {characters.length > 0 ? (
        <div class="portraits">
          {characters.map(c => (
            <a class="portrait" href={`/characters/${c.slug}`}>
              <div class="portrait-img">
                {c.data.portrait
                  ? <Image src={c.data.portrait} alt={c.data.name} width={300} height={450} class="portrait-photo" />
                  : <i class={`fa-solid ${classIcon(c.data.characterClass)}`}></i>
                }
              </div>
              <div class="portrait-caption">
                <p class="portrait-name">{c.data.name}</p>
                <p class="portrait-class">
                  {c.data.characterClass ?? 'Adventurer'}
                  {c.data.level ? ` · Lvl ${c.data.level}` : ''}
                </p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="portraits portraits--empty">
          <p class="fellowship-empty">No active characters found for this campaign.</p>
        </div>
      )}

      <div class="portraits-nav">
        <button aria-label="Previous"><i class="fa-solid fa-chevron-left"></i></button>
        <button aria-label="Next"><i class="fa-solid fa-chevron-right"></i></button>
      </div>
    </div>
  </section>

  <!-- ── CHRONICLES ──────────────────────────────────────────────────────── -->
  <section class="chronicles" id="chronicles">
    <div class="wrap">
      <h2 class="section-label">Chronicles</h2>
      <div class="chronicles-inner">

        <div class="chronicles-image">
          <Image src="/uploads/top-view-beautiful-rpg-still-life-items.jpg" alt="Chronicles" width={560} height={740} class="chronicles-image-photo" />
        </div>

        {recentSessions.length > 0 ? (
          <ul class="chronicles-list">
            {recentSessions.map(s => (
              <li>
                <a href={`/sessions/${s.slug}`} class="ch-link">
                  <span class="ch-num">Session {toRoman(s.data.sessionNumber)}</span>
                  <p class="ch-title">{stripSessionPrefix(s.data.title)}</p>
                  {s.data.summary && (
                    <p class="ch-desc">{s.data.summary}</p>
                  )}
                  <p class="ch-meta">
                    {fmtDate(s.data.date)}
                    {s.data.rewards?.xp ? <>&nbsp;&middot;&nbsp;{s.data.rewards.xp} XP</> : ''}
                    {s.data.partyPresent?.length ? <>&nbsp;&middot;&nbsp;{s.data.partyPresent.length} present</> : ''}
                  </p>
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <ul class="chronicles-list">
            <li class="chronicles-empty">
              <span class="ch-num">No sessions recorded yet</span>
              <p class="ch-desc">The chronicles are empty. Your story has yet to be written.</p>
            </li>
          </ul>
        )}

      </div>
    </div>
  </section>

  <!-- ── COMPENDIUM ──────────────────────────────────────────────────────── -->
  <section class="compendium" id="compendium">
    <div class="wrap">
      <h2 class="section-label">Compendium</h2>
      <div class="compendium-inner">

        <div class="compendium-info">
          <p class="compendium-tagline">
            A living record of the world the party is unravelling.
          </p>
          <div class="compendium-counts">
            <div class="comp-count-item">
              <p class="n">{npcs.length || 0}</p>
              <p class="lbl">NPCs</p>
            </div>
            <div class="comp-count-item">
              <p class="n">{factions.length || 0}</p>
              <p class="lbl">Factions</p>
            </div>
            <div class="comp-count-item">
              <p class="n">{items.length || 0}</p>
              <p class="lbl">Items &amp; Artifacts</p>
            </div>
            <div class="comp-count-item">
              <p class="n">{totalPins || 0}</p>
              <p class="lbl">Named Locations</p>
            </div>
          </div>
        </div>

        <div class="compendium-entries">
          <div class="comp-entry">
            <div class="comp-entry-icon">
              <i class="fa-solid fa-person-walking"></i>
            </div>
            <div class="comp-entry-body">
              <p class="comp-entry-title">NPCs</p>
              <p class="comp-entry-desc">
                Named figures of the realm — allies, enemies, and those whose allegiances have yet to be determined.
              </p>
              <p class="comp-entry-count">
                {npcs.length} {npcs.length === 1 ? 'entry' : 'entries'}
              </p>
            </div>
          </div>

          <div class="comp-entry">
            <div class="comp-entry-icon">
              <i class="fa-solid fa-flag"></i>
            </div>
            <div class="comp-entry-body">
              <p class="comp-entry-title">Factions</p>
              <p class="comp-entry-desc">
                Powers that shape the realm — guilds, orders, noble houses, and those who serve no master.
              </p>
              <p class="comp-entry-count">
                {factions.length} {factions.length === 1 ? 'faction' : 'factions'}
              </p>
            </div>
          </div>

          <div class="comp-entry">
            <div class="comp-entry-icon">
              <i class="fa-solid fa-gem"></i>
            </div>
            <div class="comp-entry-body">
              <p class="comp-entry-title">Items &amp; Artifacts</p>
              <p class="comp-entry-desc">
                Relics found, traded, and buried. Some objects have histories longer than the kingdoms that forged them.
              </p>
              <p class="comp-entry-count">
                {items.length} {items.length === 1 ? 'entry' : 'entries'}
              </p>
            </div>
          </div>

          <div class="comp-entry">
            <div class="comp-entry-icon">
              <i class="fa-solid fa-map"></i>
            </div>
            <div class="comp-entry-body">
              <p class="comp-entry-title">Maps</p>
              <p class="comp-entry-desc">
                World maps, regional charts, and dungeon layouts — with named pins and lore annotations.
              </p>
              <p class="comp-entry-count">
                {allMaps.length} {allMaps.length === 1 ? 'map' : 'maps'}
                {totalPins > 0 ? <>&nbsp;&middot;&nbsp;{totalPins} pinned {totalPins === 1 ? 'location' : 'locations'}</> : ''}
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Base>

<style>
  /* ─── Section label ─────────────────────────────────────────────── */
  .section-label {
    font-family: "Cinzel Decorative", serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    color: var(--mist-bright);
    line-height: 1;
    letter-spacing: 0.02em;
    margin-bottom: 2.5rem;
  }

  /* ─── HERO ──────────────────────────────────────────────────────── */
  .hero {
    margin-top: var(--nav-height);
    position: relative;
    height: 88vh;
    min-height: 520px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .hero-art {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to bottom,
        rgba(39, 37, 36, 0.3) 0%,
        transparent 30%,
        transparent 50%,
        var(--void-deep) 100%
      ),
      radial-gradient(
        ellipse 60% 70% at 30% 60%,
        rgba(180, 100, 80, 0.15) 0%,
        transparent 60%
      ),
      radial-gradient(
        ellipse 50% 60% at 75% 40%,
        rgba(104, 152, 168, 0.12) 0%,
        transparent 55%
      ),
      url("/hero-image.jpg");
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: saturate(0.3) sepia(0.4);
  }

  .hero-art::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .monogram-hero {
    position: absolute;
    right: 8%;
    top: 50%;
    transform: translateY(-50%);
    width: 280px;
    height: 280px;
    color: rgba(104, 152, 168, 0.35);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 2.5rem 3.5rem;
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .hero-title {
    font-family: "Cinzel Decorative", serif;
    font-size: clamp(40px, 7vw, 80px);
    font-weight: 700;
    color: var(--mist-bright);
    line-height: 1;
    letter-spacing: 0.01em;
    text-shadow: 0 2px 40px rgba(0, 0, 0, 0.6);
  }

  .hero-right {
    text-align: right;
    max-width: 280px;
    padding-bottom: 0.4rem;
  }

  .hero-tagline {
    font-family: "IM Fell English", serif;
    font-style: italic;
    font-size: 13px;
    color: var(--mist-mid);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: flex-end;
  }

  .hero-link {
    font-family: "Cinzel", serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--teal-mid);
    text-decoration: none;
    border-bottom: 1px solid rgba(104, 152, 168, 0.4);
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }

  .hero-link:hover {
    color: var(--teal-bright);
    border-color: var(--teal-bright);
  }

  .pill-active {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.2rem 0.65rem;
    border-radius: 2px;
    font-family: "Cinzel", serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: rgba(104, 152, 168, 0.1);
    border: 1px solid rgba(104, 152, 168, 0.4);
    color: var(--teal-bright);
    margin-bottom: 0.75rem;
  }

  .pill-active::before {
    content: "";
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--teal-bright);
  }

  /* ─── THE CAMPAIGN ──────────────────────────────────────────────── */
  .campaign {
    padding: 6rem 0 5rem;
    border-bottom: 1px solid var(--border-default);
    background: linear-gradient(160deg, rgba(180, 100, 80, 0.05) 0%, transparent 50%);
  }

  .campaign-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .campaign-image {
    aspect-ratio: 3/4;
    background: var(--void-raised);
    border: 1px solid var(--border-default);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(104, 152, 168, 0.15);
    font-size: 64px;
    position: relative;
    overflow: hidden;
  }

  .campaign-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(39, 37, 36, 0.6) 0%, transparent 50%);
  }

  .campaign-cover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .campaign-meta {
    font-family: "Cinzel", serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 1.25rem;
  }

  .campaign-title {
    font-family: "Cinzel Decorative", serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--mist-bright);
    line-height: 1.15;
    margin-bottom: 0.25rem;
  }

  .campaign-subtitle {
    font-family: "Cinzel", serif;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .campaign-desc {
    font-style: italic;
    font-size: 15px;
    color: var(--text-body);
    line-height: 1.85;
    margin-bottom: 1.5rem;
  }

  .campaign-callout {
    font-family: "Cinzel Decorative", serif;
    font-size: clamp(16px, 2.5vw, 22px);
    color: var(--mist-mid);
    line-height: 1.3;
    margin: 2rem 0;
    max-width: 420px;
  }

  .campaign-stats {
    display: flex;
    gap: 2rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--border-default);
    border-bottom: 1px solid var(--border-default);
    margin-bottom: 1.5rem;
  }

  .campaign-stat .lbl {
    font-family: "Cinzel", serif;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: block;
  }

  .campaign-stat .val {
    font-family: monospace;
    font-size: 14px;
    color: var(--teal-mid);
  }

  .campaign-text .btn {
    margin-right: 0.5rem;
  }

  /* ─── THE FELLOWSHIP ────────────────────────────────────────────── */
  .fellowship {
    padding: 6rem 0 5rem;
    border-bottom: 1px solid var(--border-default);
    background: linear-gradient(180deg, rgba(104, 152, 168, 0.05) 0%, transparent 60%);
  }

  .fellowship-intro {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    gap: 2rem;
  }

  .fellowship-tagline {
    font-style: italic;
    font-size: 15px;
    color: var(--text-muted);
    max-width: 260px;
    text-align: right;
    line-height: 1.65;
    padding-top: 0.5rem;
  }

  .fellowship-empty {
    font-style: italic;
    color: var(--text-dim);
    padding: 2rem 0;
  }

  .portraits {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 6px;
    margin-bottom: 1rem;
  }

  .portraits--empty {
    display: block;
  }

  .portrait {
    display: flex;
    flex-direction: column;
    cursor: pointer;
    text-decoration: none;
  }

  .portrait-img {
    aspect-ratio: 2/3;
    background: var(--void-raised);
    border: 1px solid var(--border-default);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
    color: rgba(104, 152, 168, 0.2);
    position: relative;
    overflow: hidden;
    transition: border-color 0.25s;
  }

  .portrait-img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--teal-tint);
    mix-blend-mode: multiply;
    opacity: 0.55;
    pointer-events: none;
  }

  .portrait:hover .portrait-img {
    border-color: rgba(104, 152, 168, 0.5);
  }

  .portrait-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .portrait-caption {
    padding: 0.6rem 0 0;
  }

  .portrait-name {
    font-family: "Cinzel", serif;
    font-size: 11px;
    font-weight: 600;
    color: var(--mist-mid);
    letter-spacing: 0.04em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .portrait-class {
    font-family: "Cinzel", serif;
    font-size: 9px;
    letter-spacing: 0.06em;
    color: var(--text-dim);
  }

  .portraits-nav {
    display: flex;
    gap: 0.6rem;
    margin-top: 1rem;
  }

