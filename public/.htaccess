# ─── Emberfall Keep — Apache Configuration ────────────────────────────────────

# Enable rewrite engine
RewriteEngine On

# ─── Clean URLs ───────────────────────────────────────────────────────────────
# Serve /page instead of /page.html
# First check if the exact file or directory exists — serve it directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# Then try appending .html
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
RewriteRule ^(.+)$ $1.html [L,QSA]

# ─── Trailing slash redirect ──────────────────────────────────────────────────
# Remove trailing slashes (except root) to keep URLs canonical
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# ─── Custom error pages ───────────────────────────────────────────────────────
ErrorDocument 404 /404.html
ErrorDocument 403 /404.html

# ─── Security headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    # Prevent MIME sniffing
    Header always set X-Content-Type-Options "nosniff"
    # Basic XSS protection
    Header always set X-XSS-Protection "1; mode=block"
    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # Remove server signature from responses
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# ─── Compression ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2 font/woff
</IfModule>

# ─── Browser caching ──────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # HTML — short cache, content changes often
    ExpiresByType text/html                 "access plus 1 hour"
    # CSS and JS — Astro hashes filenames, safe to cache long
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    # Fonts
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
    # Images
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 6 months"
    ExpiresByType image/png                 "access plus 6 months"
    ExpiresByType image/svg+xml             "access plus 1 month"
    ExpiresByType image/x-icon              "access plus 1 year"
    # JSON / data
    ExpiresByType application/json          "access plus 1 hour"
</IfModule>

# ─── Deny access to sensitive files ───────────────────────────────────────────
<FilesMatch "^(\.env|\.gitignore|package\.json|package-lock\.json|tsconfig\.json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to hidden files and directories (starting with .)
RewriteCond %{REQUEST_URI} (^|/)\.(?!well-known)
RewriteRule ^ - [F,L]
