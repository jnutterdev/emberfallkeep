# ─── TinaCMS Cloud ────────────────────────────────────────────────────────────
# Required when using TinaCMS Cloud for content editing.
# Get these from https://app.tina.io after creating a project.
TINA_PUBLIC_CLIENT_ID=
TINA_TOKEN=

# ─── Git Branch ───────────────────────────────────────────────────────────────
# The branch TinaCMS will read/write content to.
# Defaults to "main" if not set.
# GITHUB_BRANCH=main

# ─── Media (optional) ─────────────────────────────────────────────────────────
# Only required if using Cloudinary for media storage.
# https://tina.io/docs/reference/media/external/cloudinary/
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
